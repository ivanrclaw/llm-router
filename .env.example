# Production defaults (copy to .env.local for local development; configure real secrets via Fly secrets)
NODE_ENV=production
PORT=3001
DATABASE_PATH=/data/llm-router.sqlite
RUN_MIGRATIONS=true
SERVE_WEB_DIST=true

# Security: never commit real values
JWT_SECRET=
ENCRYPTION_KEY=

# CORS / rate limits
CORS_ORIGIN=
CORS_ORIGINS=https://llm-router.fly.dev
AUTH_RATE_LIMIT_RPM=30
V1_RATE_LIMIT_RPM=120

# Optional backup location
BACKUP_DIR=/data/backups
